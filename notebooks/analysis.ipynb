   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv(\"../data/stock_data.csv\")\n",
    "\n",
    "df['Date'] = pd.to_datetime(df['Date'])\n",
    "\n",
    "# Plot\n",
    "plt.plot(df['Date'], df['Adj Close'])\n",
    "plt.title(\"Stock Price Over Time\")\n",
    "plt.show()"
   ]
  }
